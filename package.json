{
  "name": "ai-coder",
  "version": "0.1.0",
  "description": "AI-powered coding assistant - Claude Code clone",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ai-coder": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "react": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
